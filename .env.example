# Copy to .env and adjust if needed. The defaults match docker-compose.yml.

# Host port Postgres is published on (defaults to 5433 to avoid a local 5432).
# If you change it, also update the port in DATABASE_URL below.
DB_HOST_PORT=5433

# PostgreSQL connection string used by the API (Drizzle).
DATABASE_URL=postgresql://timesheet:timesheet@localhost:5433/timesheet

# apps/api/.env.example — copy to apps/api/.env
NODE_ENV=development

# PostgreSQL connection string used by the API (Drizzle).
DATABASE_URL=postgresql://timesheet:timesheet@localhost:5433/timesheet

# Port the API server listens on.
PORT=3333

# Allowed CORS origin for the web client.
CORS_ORIGIN=http://localhost:3000

# Host port Postgres is published on (defaults to 5433 to avoid a local 5432).
# If 5433 is already taken, change this AND update the port in DATABASE_URL.
# DB_HOST_PORT=5434

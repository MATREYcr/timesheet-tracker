{
  "name": "@timesheet/e2e",
  "targets": {
    "e2e": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm exec playwright test",
        "cwd": "apps/e2e"
      }
    },
    "e2e:ui": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm exec playwright test --ui",
        "cwd": "apps/e2e"
      }
    },
    "e2e:report": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm exec playwright show-report",
        "cwd": "apps/e2e"
      }
    }
  }
}
